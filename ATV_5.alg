algoritmo "senha"
// Autor :  babi
// Data : 13/04/2026
// Seção de Declarações 
var
     senha: literal
     nome: literal
inicio
// Seção de Comandos 

   escreva ("Seu nome")
   leia (nome)
   escreva ("Digite a senha")
   leia (senha)
   se senha = "abc23" entao
   escreva ("senha correta")
   senao
   escreva ("senha incorreta")
   fimse

fimalgoritmo
