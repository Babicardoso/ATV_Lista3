algoritmo "IDADE"
// Autor :  babi
// Data : 13/04/2026
// Seçăo de Declaraçőes 
var
   Idade: real

inicio
// Seçăo de Comandos

   escreva ("Informe sua idade para verificaçăo")
   leia (Idade)
   
// Vamos calcular!!

   se idade>= 18 entao
   escreva("autorizado")
   senao
   escreva ("năo autorizado")
   fimse
fimalgoritmo
